<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"><meta name="robots" content="noindex,nofollow,noarchive"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>DocSendGo v5.0 Super Admin</title>
<script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-firestore-compat.js"></script>
<style>
:root{--nav:#0f172a;--blue:#3157e8;--bg:#f3f6fb;--card:#fff;--muted:#64748b;--danger:#dc2626;--ok:#059669}
*{box-sizing:border-box}body{margin:0;font-family:Inter,Arial,sans-serif;background:var(--bg);color:#0f172a}button,input,select,textarea{font:inherit}.hidden{display:none!important}
.login{min-height:100vh;display:grid;place-items:center;padding:24px}.login-card{width:min(430px,100%);background:#fff;padding:30px;border-radius:24px;box-shadow:0 20px 60px #0f172a20}.login-card h1{margin:0 0 8px}.field{display:grid;gap:7px;margin:14px 0}.field input,.field textarea,.field select{width:100%;padding:13px 14px;border:1px solid #d7deeb;border-radius:12px;background:#fff}.btn{border:0;border-radius:12px;padding:12px 16px;font-weight:800;cursor:pointer;background:var(--blue);color:#fff}.btn.secondary{background:#e8edff;color:#2144c6}.btn.danger{background:#fee2e2;color:#b91c1c}.btn.success{background:#dcfce7;color:#047857}.btn.small{padding:8px 11px;font-size:13px}
.app{min-height:100vh}.top{height:68px;background:var(--nav);color:#fff;display:flex;align-items:center;justify-content:space-between;padding:0 20px;position:sticky;top:0;z-index:10}.brand{font-size:19px;font-weight:900}.layout{display:grid;grid-template-columns:245px 1fr;min-height:calc(100vh - 68px)}.side{background:#fff;border-right:1px solid #e5eaf2;padding:18px 12px}.nav{display:grid;gap:7px}.nav button{border:0;background:transparent;text-align:left;padding:12px 14px;border-radius:12px;font-weight:750;color:#475569;cursor:pointer}.nav button.active,.nav button:hover{background:#e9eeff;color:#2448cf}.main{padding:24px;min-width:0}.page{display:none}.page.active{display:block}.head{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:20px}.head h2{margin:0}.grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:16px}.stat,.card{background:#fff;border:1px solid #e8edf5;border-radius:18px;box-shadow:0 8px 28px #0f172a0d}.stat{padding:20px}.stat b{font-size:30px;display:block;margin-top:8px}.card{padding:20px;margin-bottom:18px}.toolbar{display:flex;gap:10px;flex-wrap:wrap}.toolbar input,.toolbar select{padding:11px 13px;border:1px solid #d8dfeb;border-radius:11px;min-width:220px}.table-wrap{overflow:auto}.table{width:100%;border-collapse:collapse;min-width:780px}.table th,.table td{padding:12px;border-bottom:1px solid #edf1f6;text-align:left;font-size:14px}.table th{color:#64748b;background:#fafbfe}.badge{padding:5px 9px;border-radius:999px;font-size:12px;font-weight:800;background:#eef2ff;color:#3730a3}.muted{color:var(--muted)}.two{display:grid;grid-template-columns:1fr 1fr;gap:18px}.msg{min-height:20px;margin-top:10px;font-weight:700}.panel-form{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}.full{grid-column:1/-1}.checkgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}.ticket{padding:14px;border:1px solid #e5eaf2;border-radius:14px;margin:10px 0}.mobile-menu{display:none}
@media(max-width:900px){.layout{grid-template-columns:1fr}.side{display:none;position:fixed;inset:68px 0 0 0;z-index:9}.side.open{display:block}.mobile-menu{display:inline-flex}.grid{grid-template-columns:repeat(2,1fr)}.two{grid-template-columns:1fr}.main{padding:14px}.panel-form{grid-template-columns:1fr}.full{grid-column:auto}}
</style>
</head>
<body>
<section id="login" class="login"><div class="login-card"><h1>DocSendGo Admin</h1><p class="muted">Full control panel</p><div class="field"><label>Email</label><input id="email" type="email"></div><div class="field"><label>Password</label><input id="password" type="password"></div><button class="btn" onclick="loginAdmin()">Secure Login</button><div id="loginMsg" class="msg"></div></div></section>
<section id="app" class="app hidden">
<header class="top"><div><button class="btn small secondary mobile-menu" onclick="toggleMenu()">☰</button> <span class="brand">🛡️ DocSendGo v5.0 Super Admin</span> <span id="adminRoleBadge" class="badge" style="margin-left:8px"></span></div><button class="btn danger" onclick="logoutAdmin()">Logout</button></header>
<div class="layout"><aside id="side" class="side"><nav class="nav" id="nav">
<button class="active" data-page="dashboard">📊 Dashboard</button><button data-page="users">👥 Users</button><button data-page="stores">🏪 Stores</button><button data-page="orders">🧾 Orders & Bills</button><button data-page="documents">📄 Document History</button><button data-page="rewards">🎁 Referral & Coins</button><button data-page="reports">🚩 Reports</button><button data-page="helpdesk">🎫 Help Desk</button><button data-page="activity">🧭 Admin Activity</button><button data-page="settings">⚙️ Settings</button>
</nav></aside><main class="main">
<section id="dashboard" class="page active"><div class="head"><h2>Dashboard</h2><button class="btn secondary" onclick="loadDashboard()">Refresh</button></div><div class="grid"><div class="stat">Users<b id="sUsers">0</b></div><div class="stat">Stores<b id="sStores">0</b></div><div class="stat">Orders<b id="sOrders">0</b></div><div class="stat">Bills<b id="sBills">0</b></div><div class="stat">Pending Orders<b id="sPending">0</b></div><div class="stat">Open Reports<b id="sReports">0</b></div><div class="stat">Open Tickets<b id="sTickets">0</b></div><div class="stat">Total Referrals<b id="sReferrals">0</b></div><div class="stat">Document Sends<b id="sDocHistory">0</b></div></div><div class="two" style="margin-top:18px"><div class="card"><h3>Recent Stores</h3><div id="recentStores" class="muted">Loading…</div></div><div class="card"><h3>Recent Reward Updates</h3><div id="recentRewards" class="muted">Loading…</div></div></div></section>
<section id="users" class="page"><div class="head"><h2>User Management</h2></div><div class="card"><div class="toolbar"><input id="userSearch" placeholder="User ID / name / mobile"><button class="btn" onclick="findUserFull()">Find User</button></div><div id="userResult" style="margin-top:16px"></div></div></section>
<section id="stores" class="page"><div class="head"><h2>Store Management</h2><button class="btn secondary" onclick="loadStores()">Refresh</button></div><div class="card"><div class="toolbar"><input id="storeSearch" placeholder="Store name / code / owner"><select id="storeTypeFilter"><option value="">All store types</option><option>Grocery / General Store</option><option>Pharmacy / Medical Store</option><option>Xerox / Print Shop</option><option>Mobile Shop</option><option>Electronics Store</option><option>Restaurant / Food Shop</option><option>Hardware Store</option><option>Stationery / Book Shop</option><option>Other</option></select><select id="storeStatusFilter"><option value="">All status</option><option value="active">Active</option><option value="suspended">Suspended</option></select><button class="btn" onclick="filterStoreRows()">Filter</button></div></div><div class="card table-wrap"><table class="table"><thead><tr><th>Store</th><th>Type</th><th>Owner</th><th>Mobile</th><th>Code</th><th>City</th><th>Status</th><th>Actions</th></tr></thead><tbody id="storeRows"></tbody></table></div></section>
<section id="orders" class="page"><div class="head"><h2>Orders & Bills</h2><button class="btn secondary" onclick="loadOrdersBills()">Refresh</button></div><div class="card"><div class="toolbar"><input id="orderSearch" placeholder="Slip code / bill number / store code"><select id="orderStatusFilter"><option value="">All order status</option><option value="pending">Pending</option><option value="accepted">Accepted</option><option value="processing">Processing</option><option value="completed">Completed</option><option value="cancelled">Cancelled</option></select><button class="btn" onclick="loadOrdersBills()">Search</button></div></div><div class="two"><div class="card"><h3>Recent Orders</h3><div id="orderList"></div></div><div class="card"><h3>Recent Bills</h3><div id="billList"></div></div></div></section>

<section id="documents" class="page">
  <div class="head"><h2>Document Send History</h2><button class="btn secondary" onclick="loadDocumentHistory()">Refresh</button></div>
  <div class="card">
    <div class="toolbar">
      <input id="docHistorySearch" placeholder="Code / sender / receiver / filename">
      <select id="docHistoryType">
        <option value="">All types</option>
        <option value="receiver_send">Direct receiver send</option>
        <option value="share_code">Share code</option>
      </select>
      <input id="docHistoryFrom" type="date" title="From date"><input id="docHistoryTo" type="date" title="To date"><select id="docHistoryStatus">
        <option value="">All status</option>
        <option value="sent">Sent</option>
        <option value="code_created">Code created</option>
        <option value="viewed">Viewed</option>
        <option value="downloaded">Downloaded</option>
        <option value="blocked">Blocked</option>
      </select>
      <button class="btn" onclick="filterDocumentHistory()">Filter</button><button class="btn secondary" onclick="exportDocumentHistoryCSV()">Export CSV</button>
    </div>
  </div>
  <div class="grid" style="margin-bottom:18px">
    <div class="stat">Total History<b id="dhTotal">0</b></div>
    <div class="stat">Viewed<b id="dhViewed">0</b></div>
    <div class="stat">Downloaded<b id="dhDownloaded">0</b></div>
    <div class="stat">Flagged/Blocked<b id="dhBlocked">0</b></div>
  </div>
  <div class="card table-wrap">
    <table class="table" style="min-width:1150px">
      <thead><tr><th>Code</th><th>Sender</th><th>Receiver</th><th>Files</th><th>Sent</th><th>Views</th><th>Downloads</th><th>Status</th><th>Control</th></tr></thead>
      <tbody id="documentHistoryRows"></tbody>
    </table>
  </div>
</section>

<section id="rewards" class="page"><div class="head"><h2>Referral, DocCoins & Feature Manager</h2></div><div class="two"><div class="card"><div class="field"><label>User ID / Referral ID</label><input id="rewardUserId"></div><button class="btn" onclick="findRewardUser()">Find</button><div id="rewardEditor"></div></div><div class="card"><h3>Reward Rules</h3><p><b>10 Coins</b><br><span class="muted">1 new feature</span></p><p><b>20 Coins</b><br><span class="muted">+2 features (total 3)</span></p><p><b>30 Coins</b><br><span class="muted">+3 features (total 6)</span></p><p><b>50 Coins</b><br><span class="muted">Super Premium</span></p></div></div></section>
<section id="reports" class="page"><div class="head"><h2>Reports</h2><button class="btn secondary" onclick="loadReports()">Refresh</button></div><div class="card" id="reportList">No reports yet.</div></section>
<section id="helpdesk" class="page"><div class="head"><h2>Help Desk</h2><button class="btn secondary" onclick="loadTickets()">Refresh</button></div><div class="card" id="ticketList">No tickets yet.</div></section>

<section id="activity" class="page">
<div class="head"><h2>Admin Activity Log</h2><button class="btn secondary" onclick="loadAdminActivity()">Refresh</button></div>
<div class="card"><div class="toolbar">
<input id="activitySearch" placeholder="Admin email / action / details">
<select id="activityAction"><option value="">All actions</option><option value="login">Login</option><option value="block_document">Block document</option><option value="unblock_document">Unblock document</option><option value="delete_document_history">Delete history</option><option value="save_document_note">Save note</option><option value="save_settings">Settings</option></select>
<button class="btn" onclick="filterAdminActivity()">Filter</button>
<button class="btn secondary" onclick="exportAdminActivityCSV()">Export CSV</button>
</div></div>
<div class="card table-wrap"><table class="table" style="min-width:900px"><thead><tr><th>Date</th><th>Admin</th><th>Role</th><th>Action</th><th>Details</th></tr></thead><tbody id="activityRows"></tbody></table></div>
</section>

<section id="settings" class="page"><div class="head"><h2>Admin Settings</h2><button class="btn secondary" onclick="loadSettings()">Refresh</button></div><div class="two"><div class="card"><h3>Current Admin</h3><p id="adminEmail"></p><p><b>Role:</b> <span id="settingsRole"></span></p><p class="muted">Roles: superadmin, manager, support</p><p><b>Panel Version:</b> 5.4</p></div><div class="card"><h3>App Settings</h3><div class="field"><label>App Notice</label><textarea id="appNotice" placeholder="Notice shown to users"></textarea></div><div class="field"><label>Referral Feature Name</label><input id="referralFeatureName" placeholder="Early Access to New Features"></div><button class="btn" onclick="saveSettings()">Save Settings</button><div id="settingsMsg" class="msg"></div></div></div><div class="card"><h3>Recent Admin Activity</h3><div id="adminLogList" class="muted">Loading…</div></div></section>
</main></div></section>
<script>
const firebaseConfig={apiKey:'AIzaSyDR0higGBdiwGGduTLwLpjIaQ8rtuhLayI',authDomain:'docsendgo.firebaseapp.com',projectId:'docsendgo',storageBucket:'docsendgo.firebasestorage.app',messagingSenderId:'112683079074',appId:'1:112683079074:web:1b8bef5b606eb0d0760efb'};
firebase.initializeApp(firebaseConfig);const auth=firebase.auth(),db=firebase.firestore();let selectedReward=null,currentAdminRole='support',currentAdminUid=null;
const ROLE_PERMS={superadmin:['dashboard','users','stores','orders','documents','rewards','reports','helpdesk','activity','settings'],manager:['dashboard','users','stores','orders','documents','rewards','reports','activity'],support:['dashboard','documents','reports','helpdesk','activity']};
const esc=s=>String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
async function getAdminInfo(u){if(!u)return null;const d=await db.collection('admins').doc(u.uid).get();if(!d.exists||d.data().active!==true)return null;return {id:u.uid,...d.data()}}
function applyRoleUI(){document.querySelectorAll('#nav button').forEach(b=>{b.classList.toggle('hidden',!ROLE_PERMS[currentAdminRole]?.includes(b.dataset.page))});const role=document.getElementById('adminRoleBadge');if(role)role.textContent=currentAdminRole.toUpperCase()}
async function logAction(action,details=''){try{await db.collection('adminLogs').add({adminUid:currentAdminUid,adminEmail:auth.currentUser?.email||'',role:currentAdminRole,action,details,createdAt:firebase.firestore.FieldValue.serverTimestamp()})}catch{}}
auth.onAuthStateChanged(async u=>{const info=u?await getAdminInfo(u):null;if(u&&info){currentAdminUid=u.uid;currentAdminRole=info.role||'support';login.classList.add('hidden');app.classList.remove('hidden');adminEmail.textContent=u.email;applyRoleUI();loadDashboard();logAction('login')}else{app.classList.add('hidden');login.classList.remove('hidden')}});
async function loginAdmin(){loginMsg.textContent='';try{const c=await auth.signInWithEmailAndPassword(email.value.trim(),password.value);if(!(await getAdminInfo(c.user))){await auth.signOut();throw Error('This account is not an active admin.')}}catch(e){loginMsg.textContent=e.message;loginMsg.style.color='#b91c1c'}}function logoutAdmin(){auth.signOut()}function toggleMenu(){side.classList.toggle('open')}
document.querySelectorAll('#nav button').forEach(b=>b.onclick=()=>{if(!ROLE_PERMS[currentAdminRole]?.includes(b.dataset.page))return alert('Permission denied');document.querySelectorAll('#nav button').forEach(x=>x.classList.remove('active'));b.classList.add('active');document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));document.getElementById(b.dataset.page).classList.add('active');side.classList.remove('open');({dashboard:loadDashboard,stores:loadStores,orders:loadOrdersBills,documents:loadDocumentHistory,reports:loadReports,helpdesk:loadTickets,activity:loadAdminActivity,settings:loadSettings}[b.dataset.page]||(()=>{}))()});
async function countCol(n){try{const s=await db.collection(n).get();return s.size}catch{return 0}}
async function countWhere(col,field,value){try{const s=await db.collection(col).where(field,'==',value).get();return s.size}catch{return 0}}
async function loadDashboard(){
try{const dh=await db.collection('documentHistory').get();if(window.sDocHistory)sDocHistory.textContent=dh.size}catch(_){if(window.sDocHistory)sDocHistory.textContent='0'}
 const [u,s,o,b,p,r,t,rf]=await Promise.all([countCol('profiles'),countCol('stores'),countCol('storeOrders'),countCol('storeBills'),countWhere('storeOrders','status','pending'),countWhere('reports','status','open'),countWhere('supportTickets','status','open'),countCol('referrals')]);
 sUsers.textContent=u;sStores.textContent=s;sOrders.textContent=o;sBills.textContent=b;sPending.textContent=p;sReports.textContent=r;sTickets.textContent=t;sReferrals.textContent=rf;
 try{const x=await db.collection('stores').orderBy('createdAt','desc').limit(5).get();recentStores.innerHTML=x.empty?'No stores yet.':x.docs.map(d=>`<p><b>${esc(d.data().storeName||d.id)}</b><br><span class="muted">${esc(d.data().storeType||'Store')} • ${esc(d.data().storeCode||d.id)}</span></p>`).join('')}catch{recentStores.textContent='Unable to load.'}
 try{const x=await db.collection('earlyAccess').orderBy('updatedAt','desc').limit(5).get();recentRewards.innerHTML=x.empty?'No updates yet.':x.docs.map(d=>`<p><b>${esc(d.id)}</b> <span class="badge">${Number(d.data().bonusCoins||0)} bonus coins</span></p>`).join('')}catch{recentRewards.textContent='No updates yet.'}}
async function findUserFull(){const q=userSearch.value.trim();if(!q)return;userResult.innerHTML='Searching…';let doc=await db.collection('profiles').doc(q.toUpperCase()).get();if(!doc.exists){const s=await db.collection('profiles').where('mobile','==',q).limit(1).get();if(!s.empty)doc=s.docs[0]}if(!doc.exists){userResult.innerHTML='<p class="muted">User not found.</p>';return}const d=doc.data();userResult.innerHTML=`<div class="card"><h3>${esc(d.fullName||d.name||'User')}</h3><p><b>User ID:</b> ${esc(doc.id)}</p><p><b>Mobile:</b> ${esc(d.mobile||'Hidden/Not available')}</p><p><b>City:</b> ${esc(d.city||'-')}</p><p><b>Referrals:</b> ${Number(d.referralCount||0)}</p><div class="toolbar"><button class="btn secondary" onclick="openReward('${esc(doc.id)}')">Manage Rewards</button><button class="btn danger" onclick="toggleUserBlock('${esc(doc.id)}',${d.blocked? 'false':'true'})">${d.blocked?'Unblock':'Block'} User</button> <button class="btn danger" onclick="deleteUserProfile('${esc(doc.id)}')">Delete Profile</button></div></div>`}
async function toggleUserBlock(id,state){if(!['superadmin','manager'].includes(currentAdminRole))return alert('Permission denied');await db.collection('profiles').doc(id).set({blocked:state,updatedAt:firebase.firestore.FieldValue.serverTimestamp()},{merge:true});await logAction(state?'block_user':'unblock_user',id);findUserFull()}
async function deleteUserProfile(id){if(currentAdminRole!=='superadmin')return alert('Only Super Admin can delete');if(!confirm('Delete this user profile? This cannot be undone.'))return;await db.collection('profiles').doc(id).delete();await logAction('delete_user_profile',id);userResult.innerHTML='<p class="muted">Profile deleted.</p>'}
function openReward(id){document.querySelector('[data-page="rewards"]').click();rewardUserId.value=id;findRewardUser()}
async function loadStores(){storeRows.innerHTML='<tr><td colspan="8">Loading…</td></tr>';try{const s=await db.collection('stores').limit(100).get();storeRows.innerHTML=s.empty?'<tr><td colspan="8">No stores.</td></tr>':s.docs.map(x=>{const d=x.data();return `<tr data-store="${esc(((d.storeName||'')+' '+(d.storeCode||x.id)+' '+(d.ownerName||'')).toLowerCase())}" data-type="${esc(d.storeType||'')}" data-status="${esc(d.status||'active')}"><td><b>${esc(d.storeName||'-')}</b></td><td>${esc(d.storeType||'-')}</td><td>${esc(d.ownerName||'-')}</td><td>${esc(d.mobile||'-')}</td><td>${esc(d.storeCode||x.id)}</td><td>${esc(d.city||'-')}</td><td><span class="badge">${esc(d.status||'active')}</span></td><td><button class="btn small success" onclick="setStoreStatus('${x.id}','active')">Active</button> <button class="btn small danger" onclick="setStoreStatus('${x.id}','suspended')">Suspend</button> <button class="btn small danger" onclick="deleteStore('${x.id}')">Delete</button></td></tr>`}).join('')}catch(e){storeRows.innerHTML=`<tr><td colspan="8">${esc(e.message)}</td></tr>`}}
function filterStoreRows(){const q=(storeSearch.value||'').trim().toLowerCase(),t=storeTypeFilter.value,s=storeStatusFilter.value;document.querySelectorAll('#storeRows tr[data-store]').forEach(r=>{r.style.display=(!q||r.dataset.store.includes(q))&&(!t||r.dataset.type===t)&&(!s||r.dataset.status===s)?'':'none'})}
async function deleteStore(id){if(currentAdminRole!=='superadmin')return alert('Only Super Admin can delete');if(!confirm('Delete this store?'))return;await db.collection('stores').doc(id).delete();await logAction('delete_store',id);loadStores()}
async function setStoreStatus(id,status){if(!['superadmin','manager'].includes(currentAdminRole))return alert('Permission denied');await db.collection('stores').doc(id).set({status,updatedAt:firebase.firestore.FieldValue.serverTimestamp()},{merge:true});await logAction('store_'+status,id);loadStores()}
async function setOrderStatus(id,status){if(!['superadmin','manager'].includes(currentAdminRole))return alert('Permission denied');await db.collection('storeOrders').doc(id).set({status,updatedAt:firebase.firestore.FieldValue.serverTimestamp()},{merge:true});await logAction('order_'+status,id);loadOrdersBills()}
async function deleteBill(id){if(currentAdminRole!=='superadmin')return alert('Only Super Admin can delete');if(!confirm('Delete this bill?'))return;await db.collection('storeBills').doc(id).delete();await logAction('delete_bill',id);loadOrdersBills()}
async function loadOrdersBills(){const q=(document.getElementById('orderSearch')?.value||'').trim().toLowerCase(),sf=document.getElementById('orderStatusFilter')?.value||'';
 orderList.textContent='Loading…';billList.textContent='Loading…';
 try{const s=await db.collection('storeOrders').orderBy('createdAt','desc').limit(100).get();let rows=s.docs.filter(x=>{const d=x.data(),txt=((d.slipCode||x.id)+' '+(d.storeCode||'')+' '+(d.customerName||'')).toLowerCase();return (!q||txt.includes(q))&&(!sf||(d.status||'pending')===sf)});orderList.innerHTML=rows.length?rows.map(x=>{const d=x.data();return `<div class="ticket"><b>${esc(d.slipCode||x.id)}</b> <span class="badge">${esc(d.status||'pending')}</span><br><span class="muted">${esc(d.storeName||d.storeCode||'')} • ${esc(d.customerName||'Customer')}</span><div class="toolbar" style="margin-top:10px"><button class="btn small" onclick="setOrderStatus('${x.id}','accepted')">Accept</button><button class="btn small secondary" onclick="setOrderStatus('${x.id}','processing')">Processing</button><button class="btn small success" onclick="setOrderStatus('${x.id}','completed')">Complete</button><button class="btn small danger" onclick="setOrderStatus('${x.id}','cancelled')">Cancel</button></div></div>`}).join(''):'No matching orders.'}catch(e){orderList.textContent='Unable to load orders: '+e.message}
 try{const s=await db.collection('storeBills').orderBy('createdAt','desc').limit(100).get();let rows=s.docs.filter(x=>{const d=x.data(),txt=((d.billNumber||x.id)+' '+(d.slipCode||'')+' '+(d.storeCode||'')).toLowerCase();return !q||txt.includes(q)});billList.innerHTML=rows.length?rows.map(x=>{const d=x.data();return `<div class="ticket"><b>${esc(d.billNumber||x.id)}</b><br><span class="muted">Slip: ${esc(d.slipCode||'-')} • ${esc(d.storeName||d.storeCode||'')} • ₹${Number(d.grandTotal||0).toFixed(2)}</span><div class="toolbar" style="margin-top:10px"><button class="btn small secondary" onclick="printBillAdmin('${x.id}')">Print</button><button class="btn small danger" onclick="deleteBill('${x.id}')">Delete</button></div></div>`}).join(''):'No matching bills.'}catch(e){billList.textContent='Unable to load bills: '+e.message}}
async function printBillAdmin(id){const d=await db.collection('storeBills').doc(id).get();if(!d.exists)return alert('Bill not found');const x=d.data(),w=window.open('','_blank');w.document.write(`<html><head><title>${esc(x.billNumber||id)}</title><style>body{font-family:Arial;padding:30px}table{width:100%;border-collapse:collapse}td,th{border:1px solid #ddd;padding:8px}</style></head><body><h2>${esc(x.storeName||'DocSendGo Store')}</h2><p>${esc(x.storeAddress||'')} ${esc(x.storeMobile||'')}</p><h3>Bill ${esc(x.billNumber||id)}</h3><p>Slip: ${esc(x.slipCode||'-')}</p><table><tr><th>Item</th><th>Qty</th><th>Rate</th><th>Total</th></tr>${(x.items||[]).map(i=>`<tr><td>${esc(i.name||i.itemName||'')}</td><td>${esc(i.qty||i.quantity||'')}</td><td>₹${Number(i.rate||0).toFixed(2)}</td><td>₹${Number(i.total||0).toFixed(2)}</td></tr>`).join('')}</table><h2>Total ₹${Number(x.grandTotal||0).toFixed(2)}</h2></body></html>`);w.document.close();w.print()}
async function findRewardUser(){const id=rewardUserId.value.trim().toUpperCase();if(!id)return;const p=await db.collection('profiles').doc(id).get();if(!p.exists){rewardEditor.innerHTML='<p class="muted">User not found.</p>';return}const e=await db.collection('earlyAccess').doc(id).get(),pd=p.data(),ed=e.exists?e.data():{};selectedReward={id,pd,ed};const fs=ed.features||[];rewardEditor.innerHTML=`<div class="card" style="margin-top:16px"><h3>${esc(pd.fullName||pd.name||id)}</h3><p>Successful referrals: <b>${Number(pd.referralCount||0)}</b></p><div class="panel-form"><div class="field"><label>Bonus Coins (+/-)</label><input id="bonusCoins" type="number" value="${Number(ed.bonusCoins||0)}"></div><div class="field"><label>Early Access</label><select id="earlyOn"><option value="false">OFF</option><option value="true" ${ed.active?'selected':''}>ON</option></select></div><div class="full checkgrid">${[1,2,3,4,5,6].map(n=>`<label><input type="checkbox" class="feat" value="feature${n}" ${fs.includes('feature'+n)?'checked':''}> Feature #${n}</label>`).join('')}<label><input type="checkbox" id="superPremium" ${ed.superPremium?'checked':''}> Super Premium</label></div></div><button class="btn" onclick="saveReward()">Save Changes</button> <button class="btn danger" onclick="resetReward()">Reset</button><div id="rewardMsg" class="msg"></div></div>`}
async function saveReward(){if(!selectedReward)return;const features=[...document.querySelectorAll('.feat:checked')].map(x=>x.value);await db.collection('earlyAccess').doc(selectedReward.id).set({active:earlyOn.value==='true',bonusCoins:Number(bonusCoins.value||0),features,superPremium:superPremium.checked,updatedAt:firebase.firestore.FieldValue.serverTimestamp()},{merge:true});rewardMsg.textContent='Saved successfully.';rewardMsg.style.color='#047857'}
async function resetReward(){if(!selectedReward||!confirm('Reset rewards for this user?'))return;await db.collection('earlyAccess').doc(selectedReward.id).set({active:false,bonusCoins:0,features:[],superPremium:false,updatedAt:firebase.firestore.FieldValue.serverTimestamp()},{merge:true});findRewardUser()}
async function loadReports(){reportList.textContent='Loading…';try{const s=await db.collection('reports').orderBy('createdAt','desc').limit(50).get();reportList.innerHTML=s.empty?'No reports yet.':s.docs.map(x=>{const d=x.data();return `<div class="ticket"><b>${esc(d.category||'Report')}</b> <span class="badge">${esc(d.status||'open')}</span><p>${esc(d.message||d.reason||'')}</p><small>${esc(d.referenceId||x.id)}</small><div style="margin-top:10px"><button class="btn small success" onclick="resolveReport('${x.id}')">Resolve</button></div></div>`}).join('')}catch{reportList.textContent='No reports collection yet or access is not enabled.'}}
async function resolveReport(id){await db.collection('reports').doc(id).set({status:'resolved',resolvedAt:firebase.firestore.FieldValue.serverTimestamp(),resolvedBy:currentAdminUid},{merge:true});await logAction('resolve_report',id);loadReports()}
async function loadTickets(){ticketList.textContent='Loading…';try{const s=await db.collection('supportTickets').orderBy('createdAt','desc').limit(50).get();ticketList.innerHTML=s.empty?'No tickets yet.':s.docs.map(x=>{const d=x.data();return `<div class="ticket"><b>${esc(d.subject||'Support Ticket')}</b> <span class="badge">${esc(d.status||'open')}</span><p>${esc(d.message||'')}</p><div class="field"><textarea id="r_${x.id}" placeholder="Admin reply">${esc(d.adminReply||'')}</textarea></div><button class="btn small" onclick="replyTicket('${x.id}')">Save Reply</button> <button class="btn small success" onclick="closeTicket('${x.id}')">Close</button></div>`}).join('')}catch{ticketList.textContent='No supportTickets collection yet or access is not enabled.'}}
async function closeTicket(id){await db.collection('supportTickets').doc(id).set({status:'closed',updatedAt:firebase.firestore.FieldValue.serverTimestamp()},{merge:true});await logAction('close_ticket',id);loadTickets()}
async function replyTicket(id){await db.collection('supportTickets').doc(id).set({adminReply:document.getElementById('r_'+id).value,status:'answered',updatedAt:firebase.firestore.FieldValue.serverTimestamp()},{merge:true});await logAction('reply_ticket',id);loadTickets()}
async function loadSettings(){settingsRole.textContent=currentAdminRole;try{const d=await db.collection('appSettings').doc('main').get();const x=d.exists?d.data():{};appNotice.value=x.notice||'';referralFeatureName.value=x.referralFeatureName||'Early Access to New Features'}catch{}try{const s=await db.collection('adminLogs').orderBy('createdAt','desc').limit(20).get();adminLogList.innerHTML=s.empty?'No activity yet.':s.docs.map(d=>`<p><b>${esc(d.data().action||'action')}</b> — ${esc(d.data().adminEmail||'')}<br><span class="muted">${esc(d.data().details||'')}</span></p>`).join('')}catch{adminLogList.textContent='Unable to load activity logs.'}}
async function saveSettings(){if(currentAdminRole!=='superadmin')return alert('Only Super Admin can change settings');await db.collection('appSettings').doc('main').set({notice:appNotice.value.trim(),referralFeatureName:referralFeatureName.value.trim(),updatedAt:firebase.firestore.FieldValue.serverTimestamp(),updatedBy:currentAdminUid},{merge:true});await logAction('save_settings');settingsMsg.textContent='Settings saved.';settingsMsg.style.color='#047857'}

let documentHistoryCache=[];
let adminActivityCache=[];

function formatAdminDate(v){
  if(!v)return '-';
  try{if(v.toDate)return v.toDate().toLocaleString();return new Date(v).toLocaleString()}catch(_){return String(v)}
}
function timeValue(v){
  try{if(v?.toDate)return v.toDate().getTime();const t=new Date(v).getTime();return Number.isFinite(t)?t:0}catch(_){return 0}
}
function normaliseHistory(id,d,source='documentHistory'){
  const files=Array.isArray(d.files)?d.files:[];
  return {
    id, historyType:d.historyType||(source==='shares'?'share_code':'legacy'),
    shareCode:d.shareCode||(source==='shares'?id:''), sourcePath:d.sourcePath||(source==='shares'?`shares/${id}`:''),
    senderId:d.senderId||d.userId||'', senderName:d.senderName||d.customerName||d.fromName||'Guest User',
    senderMobile:d.senderMobile||d.mobile||'', receiverId:d.receiverId||d.shopId||'',
    receiverName:d.receiverName||d.shopName||'', receiverType:d.receiverType||'',
    files, fileCount:Number(d.fileCount||files.length||0),
    sentAt:d.sentAt||d.createdAt||d.submittedAt||d.updatedAt||'',
    status:d.status||(Number(d.downloadCount||0)>0?'downloaded':Number(d.viewCount||0)>0?'viewed':'sent'),
    viewCount:Number(d.viewCount||0), downloadCount:Number(d.downloadCount||0),
    blocked:d.blocked===true, flagged:d.flagged===true, adminNote:d.adminNote||'', device:d.device||'', source
  };
}
function fileSummary(files){
  if(!Array.isArray(files)||!files.length)return '-';
  const names=files.slice(0,2).map(f=>f.name||'file').join(', ');
  return esc(names+(files.length>2?` +${files.length-2}`:''));
}
async function loadDocumentHistory(){
  documentHistoryRows.innerHTML='<tr><td colspan="9">Loading document history…</td></tr>';
  try{
    const map=new Map();
    const h=await db.collection('documentHistory').limit(500).get().catch(()=>({docs:[]}));
    h.docs.forEach(x=>map.set(x.id,normaliseHistory(x.id,x.data(),'documentHistory')));
    const s=await db.collection('shares').limit(500).get().catch(()=>({docs:[]}));
    s.docs.forEach(x=>{const key='SHARE-'+x.id;if(!map.has(key))map.set(key,normaliseHistory(key,x.data(),'shares'))});
    documentHistoryCache=[...map.values()].sort((a,b)=>timeValue(b.sentAt)-timeValue(a.sentAt));
    filterDocumentHistory();
  }catch(e){documentHistoryRows.innerHTML=`<tr><td colspan="9">${esc(e.message)}</td></tr>`}
}
function filteredDocumentHistory(){
  const q=(docHistorySearch.value||'').toLowerCase().trim(),type=docHistoryType.value,status=docHistoryStatus.value;
  const from=docHistoryFrom.value?new Date(docHistoryFrom.value+'T00:00:00').getTime():0;
  const to=docHistoryTo.value?new Date(docHistoryTo.value+'T23:59:59').getTime():Infinity;
  return documentHistoryCache.filter(d=>{
    const text=((d.shareCode||d.receiverId||d.id)+' '+d.senderName+' '+d.senderId+' '+d.senderMobile+' '+d.receiverName+' '+d.receiverId+' '+d.adminNote+' '+d.files.map(f=>f.name||'').join(' ')).toLowerCase();
    const st=d.blocked?'blocked':(d.status||'sent'),t=timeValue(d.sentAt);
    return (!q||text.includes(q))&&(!type||d.historyType===type)&&(!status||st===status)&&(!t||(t>=from&&t<=to));
  });
}
function filterDocumentHistory(){renderDocumentHistory(filteredDocumentHistory())}
function renderDocumentHistory(list){
  dhTotal.textContent=list.length;dhViewed.textContent=list.filter(x=>x.viewCount>0||x.status==='viewed').length;
  dhDownloaded.textContent=list.filter(x=>x.downloadCount>0||x.status==='downloaded').length;
  dhBlocked.textContent=list.filter(x=>x.blocked||x.status==='blocked'||x.flagged).length;
  documentHistoryRows.innerHTML=!list.length?'<tr><td colspan="9">No document history found. Send a new document and refresh.</td></tr>':list.map(d=>{
    const code=d.shareCode||d.receiverId||d.id,status=d.blocked?'blocked':(d.status||'sent');
    return `<tr><td><b>${esc(code)}</b><br><span class="muted">${esc(d.historyType)}</span></td>
    <td><b>${esc(d.senderName)}</b><br><span class="muted">${esc(d.senderId||'No User ID')}${d.senderMobile?' • '+esc(d.senderMobile):''}</span></td>
    <td><b>${esc(d.receiverName||'Not opened yet')}</b><br><span class="muted">${esc(d.receiverId||d.receiverType||'-')}</span></td>
    <td>${fileSummary(d.files)}<br><span class="muted">${d.fileCount} file(s)</span></td>
    <td>${esc(formatAdminDate(d.sentAt))}</td><td>${d.viewCount}</td><td>${d.downloadCount}</td>
    <td><span class="badge">${esc(status)}</span>${d.adminNote?'<br><span class="muted">📝 '+esc(d.adminNote)+'</span>':''}</td>
    <td><button class="btn small" onclick="viewHistoryDetails('${d.id}')">Details</button>
    <button class="btn small secondary" onclick="editDocumentNote('${d.id}')">Note</button>
    <button class="btn small ${d.blocked?'success':'danger'}" onclick="toggleDocumentBlock('${d.id}',${d.blocked?'false':'true'})">${d.blocked?'Unblock':'Block'}</button>
    <button class="btn small danger" onclick="deleteDocumentHistory('${d.id}')">Delete Log</button></td></tr>`
  }).join('');
}
function viewHistoryDetails(id){
  const d=documentHistoryCache.find(x=>x.id===id);if(!d)return;
  const files=d.files.map((f,i)=>`${i+1}. ${f.name||'file'} | ${f.type||'unknown'} | ${f.size?Math.round(f.size/1024)+' KB':'size unavailable'}`).join('\n')||'No files';
  alert(`Document History\n\nCode: ${d.shareCode||d.receiverId||d.id}\nSender: ${d.senderName} (${d.senderId||'No ID'})\nSender Mobile: ${d.senderMobile||'Not saved'}\nReceiver: ${d.receiverName||'Not opened'} (${d.receiverId||'-'})\nStatus: ${d.blocked?'blocked':d.status}\nSent: ${formatAdminDate(d.sentAt)}\nViews: ${d.viewCount}\nDownloads: ${d.downloadCount}\nDevice: ${d.device||'Not saved'}\nAdmin Note: ${d.adminNote||'-'}\n\nFiles:\n${files}`);
}
async function editDocumentNote(id){
  const d=documentHistoryCache.find(x=>x.id===id);if(!d)return;
  const note=prompt('Admin note:',d.adminNote||'');if(note===null)return;
  await db.collection('documentHistory').doc(id).set({adminNote:note.trim(),noteUpdatedAt:firebase.firestore.FieldValue.serverTimestamp(),noteUpdatedBy:currentAdminUid},{merge:true});
  await logAction('save_document_note',`${id}: ${note.trim()}`);loadDocumentHistory();
}
async function toggleDocumentBlock(id,blocked){
  if(!['superadmin','manager'].includes(currentAdminRole))return alert('Permission denied');
  await db.collection('documentHistory').doc(id).set({blocked,status:blocked?'blocked':'sent',blockedAt:blocked?firebase.firestore.FieldValue.serverTimestamp():null,blockedBy:blocked?currentAdminUid:''},{merge:true});
  const d=documentHistoryCache.find(x=>x.id===id);
  if(d?.sourcePath){const p=d.sourcePath.split('/');let ref=db;for(let i=0;i<p.length;i+=2)ref=ref.collection(p[i]).doc(p[i+1]);await ref.set({blocked},{merge:true}).catch(()=>{})}
  await logAction(blocked?'block_document':'unblock_document',id);loadDocumentHistory();
}
async function deleteDocumentHistory(id){
  if(currentAdminRole!=='superadmin')return alert('Only Super Admin can delete history.');
  if(!confirm('Delete this history log?'))return;
  await db.collection('documentHistory').doc(id).delete();await logAction('delete_document_history',id);loadDocumentHistory();
}
function csvEscape(v){return '"'+String(v??'').replaceAll('"','""')+'"'}
function downloadTextFile(text,name){const a=document.createElement('a'),u=URL.createObjectURL(new Blob([text],{type:'text/csv'}));a.href=u;a.download=name;document.body.appendChild(a);a.click();a.remove();setTimeout(()=>URL.revokeObjectURL(u),3000)}
function exportDocumentHistoryCSV(){
  const rows=[['Code','Type','Sender Name','Sender ID','Sender Mobile','Receiver Name','Receiver ID','Files','Sent','Views','Downloads','Status','Admin Note']];
  filteredDocumentHistory().forEach(d=>rows.push([d.shareCode||d.receiverId||d.id,d.historyType,d.senderName,d.senderId,d.senderMobile,d.receiverName,d.receiverId,d.files.map(f=>f.name||'').join(' | '),formatAdminDate(d.sentAt),d.viewCount,d.downloadCount,d.blocked?'blocked':d.status,d.adminNote]));
  downloadTextFile('\ufeff'+rows.map(r=>r.map(csvEscape).join(',')).join('\n'),'docsendgo-document-history.csv');logAction('export_document_history',`${rows.length-1} rows`);
}
async function loadAdminActivity(){
  activityRows.innerHTML='<tr><td colspan="5">Loading…</td></tr>';
  try{const s=await db.collection('adminLogs').orderBy('createdAt','desc').limit(300).get().catch(()=>db.collection('adminLogs').limit(300).get());
    adminActivityCache=s.docs.map(x=>({id:x.id,...x.data()})).sort((a,b)=>timeValue(b.createdAt)-timeValue(a.createdAt));filterAdminActivity()}
  catch(e){activityRows.innerHTML=`<tr><td colspan="5">${esc(e.message)}</td></tr>`}
}
function filteredActivity(){
  const q=(activitySearch.value||'').toLowerCase(),act=activityAction.value;
  return adminActivityCache.filter(x=>(!act||x.action===act)&&(!q||((x.adminEmail||'')+' '+(x.action||'')+' '+(x.details||'')).toLowerCase().includes(q)));
}
function filterAdminActivity(){
  const list=filteredActivity();activityRows.innerHTML=!list.length?'<tr><td colspan="5">No admin activity found.</td></tr>':list.map(x=>`<tr><td>${esc(formatAdminDate(x.createdAt))}</td><td>${esc(x.adminEmail||x.adminUid||'-')}</td><td>${esc(x.role||'-')}</td><td><b>${esc(x.action||'-')}</b></td><td>${esc(x.details||'')}</td></tr>`).join('');
}
function exportAdminActivityCSV(){
  const rows=[['Date','Admin','Role','Action','Details'],...filteredActivity().map(x=>[formatAdminDate(x.createdAt),x.adminEmail||x.adminUid,x.role,x.action,x.details])];
  downloadTextFile('\ufeff'+rows.map(r=>r.map(csvEscape).join(',')).join('\n'),'docsendgo-admin-activity.csv');
}

</script>
</body></html>
