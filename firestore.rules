rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }
    match /admins/{uid} { allow read: if request.auth != null && request.auth.uid == uid; allow write: if isAdmin(); }
    match /adminNotifications/{id} { allow read: if true; allow write: if isAdmin(); }
    match /appConfig/{id} { allow read: if true; allow write: if isAdmin(); }
    // Compatibility rules for the current public DocSendGo v1 app.
    // Tighten these after Firebase Authentication is added to normal users.
    match /shops/{shopId} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
      match /documents/{docId} { allow read, create, update: if true; allow delete: if isAdmin() || true; }
    }
    match /shares/{shareId} { allow read, create, update: if true; allow delete: if isAdmin(); }
    // Grocery module (public number-based v1; tighten after customer/shop authentication is added)
    match /groceryOrders/{orderId} { allow read, create, update: if true; allow delete: if isAdmin(); }
    match /groceryBills/{billId} { allow read, create, update: if true; allow delete: if isAdmin(); }
  }
}
