rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }
    function isSuperAdmin() {
      return isAdmin() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin';
    }
    match /admins/{uid} { allow read: if request.auth != null && request.auth.uid == uid; allow write: if isSuperAdmin(); }
    match /adminLogs/{id} { allow create, read: if isAdmin(); allow update, delete: if isSuperAdmin(); }
    match /appSettings/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /appConfig/{id} { allow read: if true; allow write: if isAdmin(); }
    match /profiles/{userId} { allow read, create, update: if true; allow delete: if isSuperAdmin(); }
    match /earlyAccess/{userId} { allow read: if true; allow write: if isAdmin(); }
    match /referrals/{id} { allow read, create: if true; allow update, delete: if isAdmin(); }
    match /reports/{id} { allow create, read: if true; allow update, delete: if isAdmin(); }
    match /supportTickets/{id} { allow create, read: if true; allow update, delete: if isAdmin(); }
    match /adminNotifications/{id} { allow read: if true; allow write: if isAdmin(); }
    match /shops/{shopId} { allow read, create, update: if true; allow delete: if isAdmin(); match /documents/{docId} { allow read, create, update: if true; allow delete: if isAdmin(); } }
    match /documentHistory/{historyId} { allow create, update: if true; allow read, delete: if isAdmin(); }
    match /shares/{shareId} { allow read, create, update: if true; allow delete: if isAdmin(); }
    match /groceryOrders/{orderId} { allow read, create, update: if true; allow delete: if isAdmin(); }
    match /groceryBills/{billId} { allow read, create, update: if true; allow delete: if isAdmin(); }
    match /stores/{storeCode} { allow read, create, update: if true; allow delete: if isAdmin(); }
    match /storeOrders/{orderId} { allow read, create, update: if true; allow delete: if isAdmin(); }
    match /storeBills/{billId} { allow read, create, update: if true; allow delete: if isAdmin(); }
  }
}
